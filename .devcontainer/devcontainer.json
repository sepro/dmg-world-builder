{
  "name": "Proost Slide Decks",
  // Recent Python base image; the Node feature adds npm for Claude Code + tooling.
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },

  // Installed once when the container is created:
  //  - Claude Code CLI (the `claude` command, used to drive deck generation)
  //  - python-pptx so the frontend-slides PPTX import script works
  //  - playwright (optional) for the skill's PDF export script
  "postCreateCommand": "npm install -g @anthropic-ai/claude-code && pip install --user pip pillow",

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "ms-python.python",
        "ms-vscode.live-server"
      ],
      "settings": {
        "editor.formatOnSave": true
      }
    }
  },

  // Live-server / preview port for opening built decks in the browser.
  "forwardPorts": [5500],

  // Friendly note for whoever opens the container.
  "postAttachCommand": "echo 'Ready'"
}
